# 会想家后端服务配置示例
# 复制此文件为 config.yaml 并填入实际值

port: 3000

database:
  host: localhost
  port: 3306
  username: root
  password: your_password_here
  database: huixiangjia

jwt:
  secret: your-jwt-secret-key-change-in-production
  expiresIn: '7d'

wecom:
  corpId: your-wecom-corp-id
  agentId: your-wecom-agent-id
  secret: your-wecom-agent-secret

# 微信支付配置
wepay:
  appId: your-wepay-appid          # 微信支付 AppID (小程序)
  mchId: your-wepay-mchid         # 商户号
  mchKey: your-wepay-mchkey       # 商户密钥
  notifyUrl: http://your-domain.com/api/v1/payment/notify  # 支付回调地址
