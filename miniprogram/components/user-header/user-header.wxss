.user-header {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background-color: #1890ff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.info {
  flex: 1;
}

.name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.tenant {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}
