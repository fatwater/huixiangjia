.page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.scroll-area {
  height: calc(100vh - 160rpx);
}

.date-picker {
  padding: 24rpx 32rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
}

.arrow {
  font-size: 24rpx;
  color: #999999;
}

.room-list {
  padding: 0 32rpx;
}
